---
import '../styles/global.css'
import { profile } from '../content/profile'
import { pageCopy } from '../content/page-copy'
import { githubStats, proofClusters, writingEvidence } from '../content/proof'
import { researchPatterns } from '../content/research'

const copy = pageCopy
const pageTitle = `${profile.name} · Personal Value OS`
const pageDescription = `${copy.profile.valueClaim.zh} 这里展示 ${profile.name} 的当前关注、作品证据、协作方式和 AI-readable context。`
const siteUrl = 'https://peterchen1997.github.io/personal-value-os'
const canonicalUrl = `${siteUrl}/`
const socialImage = profile.avatarUrl
const repoUrl = 'https://github.com/PeterChen1997/personal-value-os'
const showRippleBanner = import.meta.env.PUBLIC_SHOW_RIPPLE_BANNER !== 'false'
const themeClass = `theme-${profile.theme.preset}`
const githubLink = profile.contactLinks.find(link => link.label === 'GitHub')
const blogLink = profile.contactLinks.find(link => link.label === 'Blog')
const primaryUrl = blogLink?.url ?? profile.contactLinks[0]?.url
const dominantLanguages = githubStats.dominantLanguages.slice(0, 5)
const [firstName = profile.name, ...lastNameParts] = profile.name.split(' ')
const lastName = lastNameParts.join(' ')
const keywords = [
  profile.name,
  profile.handle,
  profile.role,
  ...profile.secondaryRoles,
  'AI native builder',
  'product engineering',
  'proof of work',
  'personal value landing page',
  'llms.txt',
  'GitHub portfolio',
  'content judgment systems'
].join(', ')
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  inLanguage: 'zh-CN',
  dateModified: '2026-05-11',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Personal Value OS',
    url: siteUrl
  },
  mainEntity: {
    '@type': 'Person',
    name: profile.name,
    alternateName: profile.handle,
    jobTitle: profile.role,
    url: primaryUrl,
    image: profile.avatarUrl,
    sameAs: profile.contactLinks.map(link => link.url),
    knowsAbout: [
      'AI 原生产品工程',
      '内容判断系统',
      '浏览器扩展',
      '个人知识管理',
      'proof-of-work portfolio'
    ],
    description: copy.profile.oneLiner.zh,
    mainEntityOfPage: canonicalUrl
  }
}
const jsonForInlineScript = JSON.stringify(copy).replace(/</g, '\\u003c')
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={profile.name} />
    <meta name="creator" content={profile.name} />
    <meta name="publisher" content={profile.name} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="theme-color" content="#1a1815" />
    <meta name="application-name" content="Personal Value OS" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={`${profile.name} avatar`} />
    <meta property="og:image:width" content="460" />
    <meta property="og:image:height" content="460" />
    <meta property="og:site_name" content="Personal Value OS" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="profile:first_name" content={firstName} />
    {lastName && <meta property="profile:last_name" content={lastName} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/markdown" href="/personal-value-os/agent-context.md" title="Agent context" />
    <link rel="alternate" type="text/plain" href="/personal-value-os/llms.txt" title="llms.txt" />
    {profile.contactLinks.map(link => <link rel="me" href={link.url} />)}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class={themeClass}>
    {showRippleBanner && (
      <aside class="ripple-banner" aria-label="Open source repository">
        <a href={repoUrl} target="_blank" rel="noreferrer">
          <span data-i18n="ui.ripplePrefix">{copy.ui.ripplePrefix.zh}</span>
          <strong data-i18n="ui.rippleCta">{copy.ui.rippleCta.zh}</strong>
        </a>
      </aside>
    )}

    <header class="topbar">
      <a class="topbar__brand" href="#top">Personal Value OS</a>
      <nav class="topbar__nav" aria-label="Page sections">
        <a href="#now" data-i18n="ui.navNow">{copy.ui.navNow.zh}</a>
        <a href="#proof" data-i18n="ui.navProof">{copy.ui.navProof.zh}</a>
        <a href="#manual" data-i18n="ui.navManual">{copy.ui.navManual.zh}</a>
        <a href="#for-agents" data-i18n="ui.navAgent">{copy.ui.navAgent.zh}</a>
      </nav>
      <form class="language-switch" aria-label="Language switch">
        <label for="lang-zh">
          <input id="lang-zh" type="radio" name="language" value="zh" data-lang-control checked />
          <span>中文</span>
        </label>
        <label for="lang-en">
          <input id="lang-en" type="radio" name="language" value="en" data-lang-control />
          <span>EN</span>
        </label>
      </form>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero__shell">
          <span class="hero__mark" aria-hidden="true"></span>
          <div class="hero__copy">
            <p class="eyebrow" data-i18n="ui.heroEyebrow">{copy.ui.heroEyebrow.zh}</p>
            <h1 id="hero-title">{profile.name}</h1>
            <p class="role" data-i18n="profile.role">{copy.profile.role.zh}</p>
            <p class="claim" data-i18n="profile.valueClaim">{copy.profile.valueClaim.zh}</p>
            <div class="hero__rule" aria-hidden="true"></div>
            <p class="intro" data-i18n="profile.oneLiner">{copy.profile.oneLiner.zh}</p>
            <div class="focus-list" aria-label="Current focus">
              {profile.currentFocus.map((_, index) => (
                <span data-i18n={`profile.currentFocus.${index}`}>{copy.profile.currentFocus[index]?.zh}</span>
              ))}
            </div>
            <nav class="hero-actions" aria-label="Primary links">
              <a href="#proof" data-i18n="ui.primaryAction">{copy.ui.primaryAction.zh}</a>
              <a href="/personal-value-os/agent-context.md" data-i18n="ui.agentAction">{copy.ui.agentAction.zh}</a>
              {githubLink && <a href={githubLink.url} target="_blank" rel="noreferrer">GitHub</a>}
            </nav>
          </div>
          <aside class="hero__index" aria-label="Profile index">
            <dl>
              <div>
                <dt data-i18n="ui.publicRepos">{copy.ui.publicRepos.zh}</dt>
                <dd>{githubStats.publicRepos}</dd>
              </div>
              <div>
                <dt data-i18n="ui.activeRepos">{copy.ui.activeRepos.zh}</dt>
                <dd>{githubStats.activeOriginalRepos}</dd>
              </div>
              <div>
                <dt data-i18n="ui.themeLabel">{copy.ui.themeLabel.zh}</dt>
                <dd>{profile.theme.preset}</dd>
              </div>
            </dl>
          </aside>
        </div>
      </section>

      <section class="section now" id="now" aria-labelledby="now-title">
        <div class="section-heading">
          <p class="eyebrow" data-i18n="ui.nowKicker">{copy.ui.nowKicker.zh}</p>
          <h2 id="now-title" data-i18n="ui.nowTitle">{copy.ui.nowTitle.zh}</h2>
        </div>
        <div class="now-grid">
          {profile.currentFocus.map((_, index) => (
            <article>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <p data-i18n={`profile.currentFocus.${index}`}>{copy.profile.currentFocus[index]?.zh}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section stats-band" aria-label="GitHub evidence summary">
        <div class="stats-card">
          <strong>{githubStats.publicRepos}</strong>
          <span data-i18n="ui.publicRepos">{copy.ui.publicRepos.zh}</span>
        </div>
        <div class="stats-card">
          <strong>{githubStats.activeOriginalRepos}</strong>
          <span data-i18n="ui.activeRepos">{copy.ui.activeRepos.zh}</span>
        </div>
        <div class="stats-card stats-card--stack">
          <span class="stats-label" data-i18n="ui.dominantStack">{copy.ui.dominantStack.zh}</span>
          <ul class="stack-list" aria-label="Dominant public stack">
            {dominantLanguages.map(language => <li>{language}</li>)}
          </ul>
        </div>
      </section>

      <section class="section" id="proof" aria-labelledby="proof-title">
        <div class="section-heading">
          <p class="eyebrow" data-i18n="ui.proofKicker">{copy.ui.proofKicker.zh}</p>
          <h2 id="proof-title" data-i18n="ui.proofTitle">{copy.ui.proofTitle.zh}</h2>
        </div>
        <div class="cluster-stack">
          {proofClusters.map((cluster, clusterIndex) => (
            <section class="cluster" aria-labelledby={`${cluster.title}-title`}>
              <div class="cluster-heading">
                <h3 id={`${cluster.title}-title`} data-i18n={`proofClusters.${clusterIndex}.title`}>
                  {copy.proofClusters[clusterIndex]?.title.zh ?? cluster.title}
                </h3>
                <p data-i18n={`proofClusters.${clusterIndex}.angle`}>
                  {copy.proofClusters[clusterIndex]?.angle.zh ?? cluster.angle}
                </p>
              </div>
              <div class="project-grid">
                {cluster.projects.map((project, projectIndex) => (
                  <article class="project">
                    <div class="project-meta">
                      <span data-i18n={`proofClusters.${clusterIndex}.projects.${projectIndex}.kind`}>
                        {copy.proofClusters[clusterIndex]?.projects[projectIndex]?.kind.zh ?? project.kind}
                      </span>
                      <span data-i18n={`proofClusters.${clusterIndex}.projects.${projectIndex}.status`}>
                        {copy.proofClusters[clusterIndex]?.projects[projectIndex]?.status.zh ?? project.status}
                      </span>
                    </div>
                    <h4><a href={project.url} target="_blank" rel="noreferrer">{project.name}</a></h4>
                    <p class="stack" data-i18n={`proofClusters.${clusterIndex}.projects.${projectIndex}.stack`}>
                      {copy.proofClusters[clusterIndex]?.projects[projectIndex]?.stack.zh ?? project.stack}
                    </p>
                    <p data-i18n={`proofClusters.${clusterIndex}.projects.${projectIndex}.proves`}>
                      {copy.proofClusters[clusterIndex]?.projects[projectIndex]?.proves.zh ?? project.proves}
                    </p>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>

      <section class="section methods" id="methods" aria-labelledby="methods-title">
        <div class="section-heading">
          <p class="eyebrow" data-i18n="ui.methodsKicker">{copy.ui.methodsKicker.zh}</p>
          <h2 id="methods-title" data-i18n="ui.methodsTitle">{copy.ui.methodsTitle.zh}</h2>
        </div>
        <div class="methods-grid">
          {profile.valuePillars.map((_, index) => (
            <article>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3 data-i18n={`valuePillars.${index}.title`}>{copy.valuePillars[index]?.title.zh}</h3>
              <p data-i18n={`valuePillars.${index}.summary`}>{copy.valuePillars[index]?.summary.zh}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section writing" aria-labelledby="writing-title">
        <div class="section-heading">
          <p class="eyebrow" data-i18n="ui.writingKicker">{copy.ui.writingKicker.zh}</p>
          <h2 id="writing-title" data-i18n="ui.writingTitle">{copy.ui.writingTitle.zh}</h2>
        </div>
        <div class="writing-grid">
          {writingEvidence.map((group, groupIndex) => (
            <article class="panel">
              <h3 data-i18n={`writingEvidence.${groupIndex}.title`}>{copy.writingEvidence[groupIndex]?.title.zh ?? group.title}</h3>
              <p data-i18n={`writingEvidence.${groupIndex}.angle`}>{copy.writingEvidence[groupIndex]?.angle.zh ?? group.angle}</p>
              <ul class="article-list">
                {group.links.map((link, linkIndex) => (
                  <li>
                    <a href={link.url} target="_blank" rel="noreferrer" data-i18n={`writingEvidence.${groupIndex}.links.${linkIndex}.label`}>
                      {copy.writingEvidence[groupIndex]?.links[linkIndex]?.label.zh ?? link.label}
                    </a>
                    <span data-i18n={`writingEvidence.${groupIndex}.links.${linkIndex}.note`}>
                      {copy.writingEvidence[groupIndex]?.links[linkIndex]?.note.zh ?? link.note}
                    </span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section manual" id="manual" aria-labelledby="manual-title">
        <div class="section-heading">
          <p class="eyebrow" data-i18n="ui.manualKicker">{copy.ui.manualKicker.zh}</p>
          <h2 id="manual-title" data-i18n="ui.manualTitle">{copy.ui.manualTitle.zh}</h2>
        </div>
        <div class="manual-list">
          {profile.userManual.map((_, index) => (
            <article>
              <h3 data-i18n={`userManual.${index}.title`}>{copy.userManual[index]?.title.zh}</h3>
              <p data-i18n={`userManual.${index}.body`}>{copy.userManual[index]?.body.zh}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section agent" id="for-agents" aria-labelledby="agent-title">
        <div class="section-heading">
          <p class="eyebrow" data-i18n="ui.agentKicker">{copy.ui.agentKicker.zh}</p>
          <h2 id="agent-title" data-i18n="ui.agentTitle">{copy.ui.agentTitle.zh}</h2>
        </div>
        <div class="agent-shell">
          <div>
            <p class="agent-copy" data-i18n="ui.agentCopy">{copy.ui.agentCopy.zh}</p>
            <div class="agent-grid">
              <a href="/personal-value-os/llms.txt">/llms.txt</a>
              <a href="/personal-value-os/agent-context.md">/agent-context.md</a>
              <a href={repoUrl} target="_blank" rel="noreferrer">GitHub repo</a>
            </div>
          </div>
          <pre><span data-i18n="ui.themeLabel">{copy.ui.themeLabel.zh}</span>: {profile.theme.preset}
<span data-i18n="ui.themeReason">{copy.ui.themeReason.zh}</span>: <span data-i18n="theme.reason">{copy.theme.reason.zh}</span>
<span data-i18n="ui.sourceLabel">{copy.ui.sourceLabel.zh}</span>: source-data/*.md</pre>
        </div>
      </section>

      <section class="section references" aria-labelledby="references-title">
        <div class="section-heading">
          <p class="eyebrow" data-i18n="ui.referencesKicker">{copy.ui.referencesKicker.zh}</p>
          <h2 id="references-title" data-i18n="ui.referencesTitle">{copy.ui.referencesTitle.zh}</h2>
        </div>
        <div class="reference-list">
          {researchPatterns.map((pattern, index) => (
            <article>
              <h3 data-i18n={`researchPatterns.${index}.label`}>{copy.researchPatterns[index]?.label.zh ?? pattern.label}</h3>
              <p data-i18n={`researchPatterns.${index}.useInThisProject`}>
                {copy.researchPatterns[index]?.useInThisProject.zh ?? pattern.useInThisProject}
              </p>
              <a href={pattern.sourceUrl} target="_blank" rel="noreferrer">{pattern.source}</a>
            </article>
          ))}
        </div>
      </section>

      <footer class="footer">
        <div>
          <h2 data-i18n="ui.footerTitle">{copy.ui.footerTitle.zh}</h2>
          <p data-i18n="ui.location">{copy.ui.location.zh}</p>
        </div>
        <nav aria-label="Contact links">
          {profile.contactLinks.map(link => (
            <a href={link.url} target="_blank" rel="noreferrer">{link.label}</a>
          ))}
        </nav>
      </footer>
    </main>

    <script is:inline id="page-copy-json" type="application/json" set:html={jsonForInlineScript}></script>
    <script is:inline>
      const copyNode = document.getElementById('page-copy-json');
      const pageCopy = copyNode ? JSON.parse(copyNode.textContent || '{}') : {};
      const getValue = (path) => path.split('.').reduce((value, key) => value?.[key], pageCopy);
      const applyLanguage = (language) => {
        const lang = language === 'en' ? 'en' : 'zh';
        document.documentElement.lang = lang === 'zh' ? 'zh-CN' : 'en';
        document.querySelectorAll('[data-lang-control]').forEach((control) => {
          const isActive = control.value === lang;
          control.checked = isActive;
          if (isActive) {
            control.setAttribute('checked', 'checked');
          } else {
            control.removeAttribute('checked');
          }
        });
        document.querySelectorAll('[data-i18n]').forEach((node) => {
          const value = getValue(node.getAttribute('data-i18n'));
          if (value && typeof value[lang] === 'string') node.textContent = value[lang];
        });
      };

      document.querySelectorAll('[data-lang-control]').forEach((control) => {
        control.addEventListener('change', (event) => applyLanguage(event.currentTarget.value));
      });

      applyLanguage('zh');
    </script>
  </body>
</html>
