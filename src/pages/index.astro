---
import '../styles/global.css'
import { profile } from '../content/profile'
import { githubStats, proofClusters, writingEvidence } from '../content/proof'
import { researchPatterns } from '../content/research'

const pageTitle = `${profile.name} · Personal Value OS`
const pageDescription = `${profile.valueClaim} 这里展示 ${profile.name} 的当前关注、作品证据、协作方式和 AI-readable context。`
const siteUrl = 'https://peterchen1997.github.io/personal-value-os'
const canonicalUrl = `${siteUrl}/`
const socialImage = profile.avatarUrl
const repoUrl = 'https://github.com/PeterChen1997/personal-value-os'
const showRippleBanner = import.meta.env.PUBLIC_SHOW_RIPPLE_BANNER !== 'false'
const themeClass = `theme-${profile.theme.preset}`
const githubLink = profile.contactLinks.find(link => link.label === 'GitHub')
const blogLink = profile.contactLinks.find(link => link.label === 'Blog')
const primaryUrl = blogLink?.url ?? profile.contactLinks[0]?.url
const [firstName = profile.name, ...lastNameParts] = profile.name.split(' ')
const lastName = lastNameParts.join(' ')
const keywords = [
  profile.name,
  profile.handle,
  profile.role,
  ...profile.secondaryRoles,
  'AI native builder',
  'product engineering',
  'proof of work',
  'personal value landing page',
  'llms.txt',
  'GitHub portfolio',
  'content judgment systems'
].join(', ')
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  inLanguage: 'zh-CN',
  dateModified: '2026-05-11',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Personal Value OS',
    url: siteUrl
  },
  mainEntity: {
    '@type': 'Person',
    name: profile.name,
    alternateName: profile.handle,
    jobTitle: profile.role,
    url: primaryUrl,
    image: profile.avatarUrl,
    sameAs: profile.contactLinks.map(link => link.url),
    knowsAbout: [
      'AI 原生产品工程',
      '内容判断系统',
      '浏览器扩展',
      '个人知识管理',
      'proof-of-work portfolio'
    ],
    description: profile.oneLiner,
    mainEntityOfPage: canonicalUrl
  }
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={profile.name} />
    <meta name="creator" content={profile.name} />
    <meta name="publisher" content={profile.name} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="theme-color" content="#1a1815" />
    <meta name="application-name" content="Personal Value OS" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={`${profile.name} avatar`} />
    <meta property="og:image:width" content="460" />
    <meta property="og:image:height" content="460" />
    <meta property="og:site_name" content="Personal Value OS" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="profile:first_name" content={firstName} />
    {lastName && <meta property="profile:last_name" content={lastName} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/markdown" href="/personal-value-os/agent-context.md" title="Agent context" />
    <link rel="alternate" type="text/plain" href="/personal-value-os/llms.txt" title="llms.txt" />
    {profile.contactLinks.map(link => <link rel="me" href={link.url} />)}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class={themeClass}>
    {showRippleBanner && (
      <aside class="ripple-banner" aria-label="Open source repository">
        <a href={repoUrl} target="_blank" rel="noreferrer">
          <span>Ripple open source</span>
          <strong>Fork Personal Value OS</strong>
        </a>
      </aside>
    )}

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero__frame">
          <div class="hero__portrait" style={`--avatar-url: url("${profile.avatarUrl}")`} aria-hidden="true"></div>
          <div class="hero__content">
            <p class="eyebrow">Personal Value OS</p>
            <h1 id="hero-title">{profile.name}</h1>
            <p class="role">{profile.role}</p>
            <p class="claim">{profile.valueClaim}</p>
            <p class="intro">{profile.oneLiner}</p>
            <div class="focus-list" aria-label="Current focus">
              {profile.currentFocus.map(item => <span>{item}</span>)}
            </div>
            <nav class="hero-actions" aria-label="Primary links">
              <a href="#proof">看作品证据</a>
              <a href="/personal-value-os/agent-context.md">给 AI agent 的上下文</a>
              {githubLink && <a href={githubLink.url} target="_blank" rel="noreferrer">GitHub</a>}
            </nav>
          </div>
        </div>
      </section>

      <section class="section now" id="now" aria-labelledby="now-title">
        <div class="section-heading">
          <p class="eyebrow">01 · /now</p>
          <h2 id="now-title">现在关注什么。</h2>
        </div>
        <div class="now-grid">
          {profile.currentFocus.map((item, index) => (
            <article>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section stats-band" aria-label="GitHub evidence summary">
        <div>
          <strong>{githubStats.publicRepos}</strong>
          <span>public repos reviewed</span>
        </div>
        <div>
          <strong>{githubStats.activeOriginalRepos}</strong>
          <span>active original repos</span>
        </div>
        <div>
          <strong>{githubStats.dominantLanguages.slice(0, 5).join(' / ')}</strong>
          <span>dominant public stack</span>
        </div>
      </section>

      <section class="section" id="proof" aria-labelledby="proof-title">
        <div class="section-heading">
          <p class="eyebrow">02 · /proof-of-work</p>
          <h2 id="proof-title">证据，不是承诺。</h2>
        </div>
        <div class="cluster-stack">
          {proofClusters.map(cluster => (
            <section class="cluster" aria-labelledby={`${cluster.title}-title`}>
              <div class="cluster-heading">
                <h3 id={`${cluster.title}-title`}>{cluster.title}</h3>
                <p>{cluster.angle}</p>
              </div>
              <div class="project-grid">
                {cluster.projects.map(project => (
                  <article class="project">
                    <div class="project-meta">
                      <span>{project.kind}</span>
                      <span>{project.status}</span>
                    </div>
                    <h4><a href={project.url} target="_blank" rel="noreferrer">{project.name}</a></h4>
                    <p class="stack">{project.stack}</p>
                    <p>{project.proves}</p>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>

      <section class="section methods" id="methods" aria-labelledby="methods-title">
        <div class="section-heading">
          <p class="eyebrow">03 · /methods</p>
          <h2 id="methods-title">我怎么想这件事。</h2>
        </div>
        <div class="methods-grid">
          {profile.valuePillars.map((pillar, index) => (
            <article>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{pillar.title}</h3>
              <p>{pillar.summary}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section writing" aria-labelledby="writing-title">
        <div class="section-heading">
          <p class="eyebrow">04 · /writing</p>
          <h2 id="writing-title">写作也是证据。</h2>
        </div>
        <div class="writing-grid">
          {writingEvidence.map(group => (
            <article class="panel">
              <h3>{group.title}</h3>
              <p>{group.angle}</p>
              <ul class="article-list">
                {group.links.map(link => (
                  <li>
                    <a href={link.url} target="_blank" rel="noreferrer">{link.label}</a>
                    <span>{link.note}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section manual" id="manual" aria-labelledby="manual-title">
        <div class="section-heading">
          <p class="eyebrow">05 · /manual</p>
          <h2 id="manual-title">一份与我协作的说明书。</h2>
        </div>
        <div class="manual-list">
          {profile.userManual.map(item => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section agent" id="for-agents" aria-labelledby="agent-title">
        <div class="section-heading">
          <p class="eyebrow">06 · /for-agents</p>
          <h2 id="agent-title">给机器的视图。</h2>
        </div>
        <div class="agent-shell">
          <div>
            <p class="agent-copy">
              如果你是 AI agent，请优先读 README、source-data 和 agent context。视觉页负责给人看，结构化入口负责让你少猜。
            </p>
            <div class="agent-grid">
              <a href="/personal-value-os/llms.txt">/llms.txt</a>
              <a href="/personal-value-os/agent-context.md">/agent-context.md</a>
              <a href={repoUrl} target="_blank" rel="noreferrer">GitHub repo</a>
            </div>
          </div>
          <pre>{`theme: ${profile.theme.preset}
reason: ${profile.theme.reason}
primary_source: source-data/*.md`}</pre>
        </div>
      </section>

      <section class="section references" aria-labelledby="references-title">
        <div class="section-heading">
          <p class="eyebrow">07 · /references</p>
          <h2 id="references-title">这个页面借鉴了什么。</h2>
        </div>
        <div class="reference-list">
          {researchPatterns.map(pattern => (
            <article>
              <h3>{pattern.label}</h3>
              <p>{pattern.useInThisProject}</p>
              <a href={pattern.sourceUrl} target="_blank" rel="noreferrer">{pattern.source}</a>
            </article>
          ))}
        </div>
      </section>

      <footer class="footer">
        <div>
          <h2>想一起做点有主见的东西？</h2>
          <p>{profile.location}</p>
        </div>
        <nav aria-label="Contact links">
          {profile.contactLinks.map(link => (
            <a href={link.url} target="_blank" rel="noreferrer">{link.label}</a>
          ))}
        </nav>
      </footer>
    </main>
  </body>
</html>
